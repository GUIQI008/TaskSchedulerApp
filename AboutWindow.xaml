<hc:Window x:Class="TaskSchedulerApp.Views.AboutWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           mc:Ignorable="d"
           Title="关于应用" Height="450" Width="380"
           WindowStartupLocation="CenterOwner"
           ResizeMode="NoResize"
           ShowInTaskbar="False"
           Background="{DynamicResource SecondaryRegionBrush}">

    <Border Margin="20" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Logo & Title -->
                <RowDefinition Height="*"/>
                <!-- Message -->
                <RowDefinition Height="Auto"/>
                <!-- QR Codes -->
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,25,0,15">

                <Image Source="/Resources/ico.png"
       Width="60" 
       RenderOptions.BitmapScalingMode="HighQuality" 
       />

                <TextBlock Text="GameSchedule" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4" Padding="6,2">
                        <TextBlock x:Name="VersionText" Text="v1.0.0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- 2. 开发者寄语 -->
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" 
                       Foreground="#888" FontSize="13" LineHeight="20" Margin="30,158,30,0"
                       VerticalAlignment="Top" Height="87" Grid.RowSpan="3">
                感谢使用本工具！<LineBreak/>
                如果这个工具帮助到了你，<LineBreak/>
                欢迎请作者喝一杯咖啡 ☕
            </TextBlock>

            <!-- 3. 捐赠区域 -->
            <Grid Grid.Row="2" Margin="0,0,0,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="1" Columns="2" HorizontalAlignment="Center" Width="260" Margin="0,10,0,-10">
                    <!-- 微信 -->
                    <StackPanel HorizontalAlignment="Center" Margin="5">
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="#EEE" Background="White" Padding="5">
                            <Image Source="/Resources/wx.jpg" Width="100" Height="108" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Path Data="M12 2C6.5 2 2 6 2 11c0 2.8 2.1 5.2 5.3 6.5.1.8-.5 2.5-1.3 3.4 1.8 0 3.7-1.1 5-2.2.3.1.7.1 1 .1 5.5 0 10-4 10-9S17.5 2 12 2z" 
                                  Fill="#09BB07" Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="微信" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 支付宝 -->
                    <StackPanel HorizontalAlignment="Center" Margin="5">
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="#EEE" Background="White" Padding="5">
                            <Image Source="/Resources/zfb.jpg" Width="100" Height="108" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" 
                                  Fill="#1678FF" Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="支付宝" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </Grid>
    </Border>
</hc:Window>