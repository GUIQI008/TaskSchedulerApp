<Window x:Class="TaskSchedulerApp.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="600" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- 浅色主题配色 -->
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="PrimaryAccent" Color="#FF2E7D32"/>
        <!-- 深绿色按钮 -->
        <SolidColorBrush x:Key="TextPrimary" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF666666"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="CloseHover" Color="#FFD32F2F"/>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF999999"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CloseHover}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 浅色卡片 -->
    <Border Background="{StaticResource CardBackground}" 
            CornerRadius="16" 
            BorderThickness="1" 
            BorderBrush="{StaticResource BorderBrush}"
            Margin="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- Logo -->
                <RowDefinition Height="Auto"/>
                <!-- 寄语 -->
                <RowDefinition Height="Auto"/>
                <!-- 二维码图片 -->
                <RowDefinition Height="Auto"/>
                <!-- 二维码文字 -->
                <RowDefinition Height="Auto"/>
                <!-- 按钮 -->
            </Grid.RowDefinitions>

            <!-- 标题栏（可拖动 + 关闭按钮） -->
            <Grid Grid.Row="0" Height="36" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
                <TextBlock Text="关于" Foreground="{StaticResource TextSecondary}" 
                           VerticalAlignment="Center" Margin="14,0,0,0" FontSize="12"/>
                <Button Content="✕" Style="{StaticResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="CloseButton_Click" Margin="0,0,8,0"/>
            </Grid>

            <!-- Logo & 版本 -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,10,0,5">
                <Image Source="/Resources/ico.png" Width="70" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="TaskScheduler" FontSize="22" FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <Border Background="{StaticResource PrimaryAccent}" CornerRadius="6" 
                        Padding="8,4" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <TextBlock x:Name="VersionText" Text="v1.0.0" 
                               Foreground="White" FontSize="12" FontWeight="Bold"/>
                </Border>
            </StackPanel>

            <!-- 寄语 -->
            <TextBlock Grid.Row="2" TextWrapping="Wrap" TextAlignment="Center" 
                       Foreground="{StaticResource TextSecondary}" FontSize="13" LineHeight="22" 
                       Margin="30,8,30,10">
                感谢使用本工具！<LineBreak/>
                如果这个工具帮助到了你，<LineBreak/>
                欢迎请作者喝一杯咖啡 ☕
            </TextBlock>

            <!-- 二维码图片 -->
            <Grid Grid.Row="3" Margin="20,5,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- 微信 -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Border CornerRadius="12" BorderThickness="1" 
                            BorderBrush="{StaticResource BorderBrush}" Background="White" Padding="8">
                        <Image Source="/Resources/wx.jpg" Width="140" Height="140" 
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </StackPanel>
                <!-- 支付宝 -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <Border CornerRadius="12" BorderThickness="1" 
                            BorderBrush="{StaticResource BorderBrush}" Background="White" Padding="8">
                        <Image Source="/Resources/zfb.jpg" Width="140" Height="140" 
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 二维码文字 -->
            <Grid Grid.Row="4" Margin="20,4,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="微信" FontSize="12" 
                           Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="支付宝" FontSize="12" 
                           Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 检查更新按钮 -->
            <Button Grid.Row="5" x:Name="BtnCheckUpdate" Content="检查更新" 
                    Style="{StaticResource AccentButton}" 
                    Click="BtnCheckUpdate_Click"
                    HorizontalAlignment="Center" Margin="0,15,0,30"/>
        </Grid>
    </Border>
</Window>