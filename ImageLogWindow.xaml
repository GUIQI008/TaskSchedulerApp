<hc:Window x:Class="TaskSchedulerApp.ImageLogWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="图片日志查看器" Height="600" Width="800"
           WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F0F0" Margin="10">
            <Image x:Name="ImgDisplay" Stretch="Uniform" />
        </Border>

        <TextBlock x:Name="TxtNoData" Grid.Row="0" Text="这里什么都没有呢" 
                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                   FontSize="20" Foreground="Gray" Visibility="Collapsed"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="&lt; 上一张" Click="Prev_Click" Width="100" Margin="10,0"/>

            <StackPanel VerticalAlignment="Center" Margin="20,0">
                <TextBlock x:Name="TxtFileName" Text="Filename.png" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtCounter" Text="0 / 0" HorizontalAlignment="Center" Foreground="Gray"/>
            </StackPanel>

            <Button Content="下一张 &gt;" Click="Next_Click" Width="100" Margin="10,0"/>
        </StackPanel>
    </Grid>
</hc:Window>