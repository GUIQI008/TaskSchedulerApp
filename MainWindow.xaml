<hc:Window x:Class="TaskSchedulerApp.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="TaskScheduler" Height="768" Width="1100"
           WindowStartupLocation="CenterScreen"
           Background="{DynamicResource SecondaryRegionBrush}">

    <hc:Window.Resources>
        <Geometry x:Key="ConfigGeometry">M19.43 12.98c.04-.32.07-.64.07-.98 0-.34-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98 0 .33.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z</Geometry>
    </hc:Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,15" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <Button Command="{Binding SaveConfigCommand}" Style="{StaticResource ButtonPrimary}" Content="💾 保存配置" Height="39" Margin="20,0,0,0" hc:BorderElement.CornerRadius="6" Width="101"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenAboutCommand}" ToolTip="关于应用" Width="40" Height="40" Background="Transparent" BorderThickness="0" hc:BorderElement.CornerRadius="20" Margin="0,0,5,0">
                        <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" Fill="#555" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                    <Button Command="{Binding OpenSettingsCommand}" ToolTip="高级设置" Width="40" Height="40" Background="Transparent" BorderThickness="0" hc:BorderElement.CornerRadius="20">
                        <Path Data="{StaticResource ConfigGeometry}" Fill="#555" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="0,0,15,0" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📋 任务队列" Style="{StaticResource TextBlockTitle}" Margin="5,5,0,15"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Settings.TaskList}" SelectedItem="{Binding SelectedTask}" IsEnabled="{Binding IsNotRunning}" ScrollViewer.VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SecondaryRegionBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" Width="4" Height="16" CornerRadius="2" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                                    <Border Grid.Column="2" CornerRadius="4" Background="#DDD" Padding="6,2" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Status}" Foreground="#555" FontSize="11"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <UniformGrid Grid.Row="2" Rows="1" Margin="0,15,0,5" IsEnabled="{Binding IsNotRunning}">
                        <Button Content="➕" Command="{Binding AddTaskCommand}" Margin="2" Height="32"/>
                        <Button Content="➖" Command="{Binding RemoveTaskCommand}" Margin="2" Height="32"/>
                        <Button Content="⬆" Command="{Binding MoveUpCommand}" Margin="2" Height="32"/>
                        <Button Content="⬇" Command="{Binding MoveDownCommand}" Margin="2" Height="32"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
                <Grid Margin="20,10,20,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,10,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <TextBlock Text="✏ 参数编辑" Style="{StaticResource TextBlockTitle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedTask.Name, StringFormat=' - {0}'}" VerticalAlignment="Center" Foreground="Gray" FontSize="16" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                        <StackPanel IsEnabled="{Binding IsTaskSelected}">

                            <!-- ================= 1. 基础设置卡片 ================= -->
                            <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="⚙ 基础配置" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <hc:TextBox Grid.Column="0" hc:InfoElement.Title="任务名称" Text="{Binding SelectedTask.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}"/>
                                        <hc:TextBox Grid.Column="2" hc:InfoElement.Title="最大运行时间 (分钟)" Text="{Binding SelectedTask.RunTime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="到点自动结束"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ================= 2. 游戏程序卡片 ================= -->
                            <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="🎮 步骤一：前置游戏程序 (可选)" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <hc:TextBox Grid.Column="0" hc:InfoElement.Title="程序路径" Text="{Binding SelectedTask.ExtraStartPath}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="游戏的 .exe 或启动器路径..."/>
                                        <Button Grid.Column="1" Content="📂" Command="{Binding BrowseExtraFileCommand}" Margin="8,26,0,0" Width="40" Height="30"/>
                                    </Grid>
                                    <hc:TextBox hc:InfoElement.Title="启动参数" Text="{Binding SelectedTask.ExtraStartArguments, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <hc:TextBox Grid.Column="0" hc:InfoElement.Title="游戏窗口标题 (Title)" Text="{Binding SelectedTask.WindowTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="精确匹配，用于判断游戏启动成功"/>
                                        <hc:TextBox Grid.Column="2" hc:InfoElement.Title="寻找超时 (秒)" Text="{Binding SelectedTask.RecognitionTimeout, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ================= 3. 脚本程序卡片 ================= -->
                            <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="🤖 步骤二：脚本/辅助工具 (可选)" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <hc:TextBox Grid.Column="0" hc:InfoElement.Title="程序路径" Text="{Binding SelectedTask.Path}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="外挂、脚本辅助工具的路径..."/>
                                        <Button Grid.Column="1" Content="📂" Command="{Binding BrowseFileCommand}" Margin="8,26,0,0" Width="40" Height="30"/>
                                    </Grid>
                                    <hc:TextBox hc:InfoElement.Title="启动参数" Text="{Binding SelectedTask.Arguments, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <hc:TextBox Grid.Column="0" hc:InfoElement.Title="脚本窗口标题 (宏霸体防遮挡专用)" Text="{Binding SelectedTask.ScriptWindowTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="必须填准，宏点击时靠它置顶防遮挡！"/>
                                        <hc:TextBox Grid.Column="2" hc:InfoElement.Title="寻找超时 (秒)" Text="{Binding SelectedTask.ScriptRecognitionTimeout, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ================= 4. 进程监控卡片 ================= -->
                            <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="🛡 进程监控与防断线" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <hc:TextBox Grid.Column="0" hc:InfoElement.Title="监控进程 (逗号分隔)" Text="{Binding SelectedTask.ProcessNames, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="丢失后立刻终止任务"/>
                                        <hc:TextBox Grid.Column="2" hc:InfoElement.Title="结束强制查杀 (逗号分隔)" Text="{Binding SelectedTask.ExtraProcessNames, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="防止残留进程占用内存"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ================= 5. 宏录制卡片 ================= -->
                            <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="🖱 步骤三：宏动作录制" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            <TextBlock Text="💡 按 F9 录制单击，或按 Ctrl+F9 开启连点录制。" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold"/>
                                            <TextBlock Text="提示: 列表中可双击修改参数，选中行按 Delete 键删除。" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="🗑 清空" Command="{Binding ClearMacrosCommand}" Style="{StaticResource ButtonDanger}" Width="60" Margin="0,0,10,0" hc:BorderElement.CornerRadius="4"/>
                                        <Button Grid.Column="2" Content="▶ 测试回放" Command="{Binding TestClickCommand}" Style="{StaticResource ButtonPrimary}" Width="90" hc:BorderElement.CornerRadius="4"/>
                                    </Grid>

                                    <!-- 限制表格高度防止太长 -->
                                    <DataGrid Height="160"
                                              ItemsSource="{Binding SelectedTask.Actions}" 
                                              AutoGenerateColumns="False" 
                                              CanUserAddRows="False" 
                                              HeadersVisibility="Column"
                                              Background="{DynamicResource RegionBrush}"
                                              BorderBrush="{DynamicResource BorderBrush}"
                                              BorderThickness="1"
                                              hc:DataGridAttach.ShowRowNumber="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="动作" Binding="{Binding ActionType}" IsReadOnly="True" Width="80"/>
                                            <DataGridTextColumn Header="X 坐标" Binding="{Binding X}" Width="70"/>
                                            <DataGridTextColumn Header="Y 坐标" Binding="{Binding Y}" Width="70"/>
                                            <DataGridTextColumn Header="前置等待(ms)" Binding="{Binding DelayBefore}" Width="100"/>
                                            <DataGridTextColumn Header="备注说明" Binding="{Binding Description}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Rectangle Height="20"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,15,0,0" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#2D2D2D" CornerRadius="8,8,0,0" Padding="10,5">
                            <TextBlock Text=">_ System Log" Foreground="#AAA" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                        <ListBox Grid.Row="1" ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Hidden" Margin="5" x:Name="LogListBox">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="Transparent" Padding="2">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Consolas, Lucida Console" FontSize="12" TextWrapping="Wrap">
                                        <Run Text="{Binding Time, StringFormat=[{0}]}" Foreground="#888"/>
                                        <Run Text="{Binding Message}" Foreground="{Binding Color}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                    <Button Content="🖼 查看截图日志" Command="{Binding ShowImageLogCommand}" Height="38" Width="180" Margin="0,0,0,15" FontSize="13" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" hc:BorderElement.CornerRadius="6"/>
                    <Button Content="🚀 开始任务循环" Command="{Binding StartTaskCommand}" Style="{StaticResource ButtonSuccess}" IsEnabled="{Binding IsNotRunning}" Height="42" Width="180" Margin="0,0,0,12" FontSize="15" FontWeight="Bold" hc:BorderElement.CornerRadius="6"/>
                    <Button Content="⛔ 停止所有任务" Command="{Binding StopTaskCommand}" Style="{StaticResource ButtonDanger}" IsEnabled="{Binding IsRunning}" Height="42" Width="180" FontSize="15" FontWeight="Bold" hc:BorderElement.CornerRadius="6"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</hc:Window>