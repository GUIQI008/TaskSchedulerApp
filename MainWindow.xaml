<hc:Window x:Class="TaskSchedulerApp.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="GameSchedule" Height="768" Width="1100"
           WindowStartupLocation="CenterScreen"
           Background="{DynamicResource SecondaryRegionBrush}">

    <hc:Window.Resources>
        <Geometry x:Key="ConfigGeometry">M19.43 12.98c.04-.32.07-.64.07-.98 0-.34-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98 0 .33.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z</Geometry>
    </hc:Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,15" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <Button Command="{Binding SaveConfigCommand}" Style="{StaticResource ButtonPrimary}" Content="💾 保存配置" Height="39" Margin="20,0,0,0" hc:BorderElement.CornerRadius="6" Width="101"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenAboutCommand}" ToolTip="关于应用" Width="40" Height="40" Background="Transparent" BorderThickness="0" hc:BorderElement.CornerRadius="20" Margin="0,0,5,0">
                        <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" Fill="#555" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                    <Button Command="{Binding OpenSettingsCommand}" ToolTip="高级设置" Width="40" Height="40" Background="Transparent" BorderThickness="0" hc:BorderElement.CornerRadius="20">
                        <Path Data="{StaticResource ConfigGeometry}" Fill="#555" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="0,0,15,0" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📋 任务队列" Style="{StaticResource TextBlockTitle}" Margin="5,5,0,15"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Settings.TaskList}" SelectedItem="{Binding SelectedTask}" IsEnabled="{Binding IsNotRunning}" ScrollViewer.VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SecondaryRegionBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" Width="4" Height="16" CornerRadius="2" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                                    <Border Grid.Column="2" CornerRadius="4" Background="#DDD" Padding="6,2" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Status}" Foreground="#555" FontSize="11"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <UniformGrid Grid.Row="2" Rows="1" Margin="0,15,0,5" IsEnabled="{Binding IsNotRunning}">
                        <Button Content="➕" Command="{Binding AddTaskCommand}" Margin="2" Height="32"/>
                        <Button Content="➖" Command="{Binding RemoveTaskCommand}" Margin="2" Height="32"/>
                        <Button Content="⬆" Command="{Binding MoveUpCommand}" Margin="2" Height="32"/>
                        <Button Content="⬇" Command="{Binding MoveDownCommand}" Margin="2" Height="32"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
                <Grid Margin="20,10,20,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,10,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <TextBlock Text="✏ 参数编辑" Style="{StaticResource TextBlockTitle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedTask.Name, StringFormat=' - {0}'}" VerticalAlignment="Center" Foreground="Gray" FontSize="16" Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Column="2" IsEnabled="{Binding IsTaskSelected}">
                            <Button Content="▶ 调试运行" Command="{Binding DebugRunCommand}" Style="{StaticResource ButtonInfo}" Margin="0,0,10,0" Height="30" Padding="10,0" hc:BorderElement.CornerRadius="4"/>
                            <Button Content="📂 打开程序" Command="{Binding OpenProgramCommand}" Margin="0,0,0,0" Height="30" Padding="10,0" hc:BorderElement.CornerRadius="4"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                        <StackPanel IsEnabled="{Binding IsTaskSelected}">
                            <hc:Divider Content="基础信息" Margin="0,0,0,15"/>
                            <hc:TextBox hc:InfoElement.Title="任务名称" Text="{Binding SelectedTask.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" Margin="0,8"/>
                            <TextBlock Text="程序路径" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,8,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <hc:TextBox Text="{Binding SelectedTask.Path}" Grid.Column="0" hc:InfoElement.Placeholder="请选择exe文件..."/>
                                <Button Content="📂" Command="{Binding BrowseFileCommand}" Grid.Column="1" Margin="8,0,0,0" Width="45"/>
                            </Grid>
                            <hc:TextBox hc:InfoElement.Title="启动参数" Text="{Binding SelectedTask.Arguments, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" Margin="0,8" hc:InfoElement.Placeholder="可选 (例如: -autorun)"/>

                            <hc:Divider Content="前置/额外启动 (可选)" Margin="0,20,0,15"/>
                            <TextBlock Text="额外程序路径 (在主程序启动前运行)" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <hc:TextBox Text="{Binding SelectedTask.ExtraStartPath}" Grid.Column="0" hc:InfoElement.Placeholder="例如: 代理软件、修改器等..."/>
                                <Button Content="📂" Command="{Binding BrowseExtraFileCommand}" Grid.Column="1" Margin="8,0,0,0" Width="45"/>
                            </Grid>
                            <hc:TextBox hc:InfoElement.Title="额外程序参数" Text="{Binding SelectedTask.ExtraStartArguments, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" Margin="0,8" hc:InfoElement.Placeholder="可选"/>

                            <hc:Divider Content="监控与清理" Margin="0,20,0,15"/>
                            <Grid Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="窗口标题 (Title)" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <hc:TextBox Text="{Binding SelectedTask.WindowTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="用于判定启动成功"/>
                                </StackPanel>
                                <hc:TextBox Grid.Column="2" hc:InfoElement.Title="监控进程 (Process)" Text="{Binding SelectedTask.ProcessNames, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" hc:InfoElement.Placeholder="智能监控, 逗号分隔" VerticalAlignment="Top"/>
                            </Grid>
                            <hc:TextBox hc:InfoElement.Title="额外进程清理 (Extra Kill)" Text="{Binding SelectedTask.ExtraProcessNames, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}" Margin="0,8" hc:InfoElement.Placeholder="任务结束时强制查杀，逗号分隔"/>
                            <Grid Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <hc:TextBox Grid.Column="0" hc:InfoElement.Title="识别超时 (秒)" Text="{Binding SelectedTask.RecognitionTimeout, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}"/>
                                <hc:TextBox Grid.Column="2" hc:InfoElement.Title="最大运行时间 (分钟)" Text="{Binding SelectedTask.RunTime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}"/>
                            </Grid>

                            <hc:Divider Content="模拟操作 (可选)" Margin="0,20,0,15"/>
                            <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="6" Padding="15" Background="{DynamicResource SecondaryRegionBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <hc:TextBox Grid.Column="0" hc:InfoElement.Title="X 坐标" Text="{Binding SelectedTask.PosX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}"/>
                                    <hc:TextBox Grid.Column="2" hc:InfoElement.Title="Y 坐标" Text="{Binding SelectedTask.PosY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxExtend}"/>
                                    <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Bottom" Margin="15,0,0,2">
                                        <Button Content="🖱 测试点击" Command="{Binding TestClickCommand}" Style="{StaticResource ButtonInfo}" Width="100"/>
                                        <TextBlock Text="按 F9 录制坐标" HorizontalAlignment="Center" FontSize="10" Foreground="Gray" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Rectangle Height="20"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,15,0,0" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow2}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#2D2D2D" CornerRadius="8,8,0,0" Padding="10,5">
                            <TextBlock Text=">_ System Log" Foreground="#AAA" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                        <ListBox Grid.Row="1" ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Hidden" Margin="5" x:Name="LogListBox">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="Transparent" Padding="2">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Consolas, Lucida Console" FontSize="12" TextWrapping="Wrap">
                                        <Run Text="{Binding Time, StringFormat=[{0}]}" Foreground="#888"/>
                                        <Run Text="{Binding Message}" Foreground="{Binding Color}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                    <Button Content="🖼 查看截图日志" Command="{Binding ShowImageLogCommand}" Height="38" Width="180" Margin="0,0,0,15" FontSize="13" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" hc:BorderElement.CornerRadius="6"/>
                    <Button Content="🚀 开始任务循环" Command="{Binding StartTaskCommand}" Style="{StaticResource ButtonSuccess}" IsEnabled="{Binding IsNotRunning}" Height="42" Width="180" Margin="0,0,0,12" FontSize="15" FontWeight="Bold" hc:BorderElement.CornerRadius="6"/>
                    <Button Content="⛔ 停止所有任务" Command="{Binding StopTaskCommand}" Style="{StaticResource ButtonDanger}" IsEnabled="{Binding IsRunning}" Height="42" Width="180" FontSize="15" FontWeight="Bold" hc:BorderElement.CornerRadius="6"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</hc:Window>