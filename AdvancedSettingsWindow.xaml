<hc:Window x:Class="TaskSchedulerApp.AdvancedSettingsWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="高级设置" Height="500" Width="500" 
           ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <GroupBox Header="Bark 推送设置">
            <StackPanel>
                <hc:TextBox hc:InfoElement.Title="Server URL" Text="{Binding BarkUrl}" Style="{StaticResource TextBoxExtend}" Margin="0,5"/>
                <hc:TextBox hc:InfoElement.Title="Icon URL" Text="{Binding BarkIcon}" Style="{StaticResource TextBoxExtend}" Margin="0,5"/>
                <Button Content="测试推送" Click="TestPush_Click" HorizontalAlignment="Right" Margin="0,10,0,0"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="系统设置" Margin="0,10,0,0">
            <StackPanel>

                <TextBlock Text="截图保存路径" Margin="0,5,0,2" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <hc:TextBox Text="{Binding ScreenshotPath}" Style="{StaticResource TextBoxExtend}"/>
                    <Button Grid.Column="1" Content="📂" Click="SelectScreenshotFolder_Click" Margin="5,0,0,0" Width="40"/>
                </Grid>

                <TextBlock Text="运行日志保存路径" Margin="0,5,0,2" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <hc:TextBox Text="{Binding LogPath}" Style="{StaticResource TextBoxExtend}"/>
                    <Button Grid.Column="1" Content="📂" Click="SelectLogFolder_Click" Margin="5,0,0,0" Width="40"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="完成后操作：" VerticalAlignment="Center" Width="100"/>
                    <ComboBox SelectedValue="{Binding OnCompletionAction}" SelectedValuePath="Content" Width="200">
                        <ComboBoxItem Content="No Action"/>
                        <ComboBoxItem Content="Shutdown"/>
                        <ComboBoxItem Content="Sleep"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <Button Content="保存并关闭" Click="SaveAndClose_Click" Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Right" Margin="0,20,0,0"/>
    </StackPanel>
</hc:Window>